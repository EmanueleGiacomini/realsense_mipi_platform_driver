From: Emanuele Giacomini <giacomini@diag.uniroma1.it>
Date: Tue, 28 Apr 2026 13:00:00 +0200
Subject: [PATCH] LIJAG: simplify max96712_setup_link for single-camera

The upstream max96712_setup_link iterates over each enabled link, briefly
toggling LINK_EN to single-link patterns (0xF1, 0xF2, 0xF4, 0xF8) and
issuing max96712_reset_oneshot() between each toggle. reset_oneshot
writes 0x0018 = 0x0F which resets ALL FOUR GMSL links simultaneously.

On the LI-JAG-ADP-GMSL2-8CH board with a single D457 attached to link A,
this combination wedges the camera-side MAX9295 forward I2C channel:
the GMSL link still reaches video lock (0x001A bit 4 set) but no
register reads or writes from the deserializer to the serializer ever
complete. Confirmed live with i2ctransfer probes after probe — bus2:0x40
returns "Remote I/O error" forever.

Replace the iteration with a single LINK_EN write covering all
configured links. Combined with link-mask=0xf in DT (final LINK_EN=0xFF,
the only value observed to keep forward I2C alive on this board), the
camera-side MAX9295 stays at its default 0x40 address and is reachable
immediately, allowing d4xx probe to complete and 7 V4L2 video devices
to enumerate for the D457.

Mark max96712_read_slave_reg / max96712_write_slave_reg with
__maybe_unused since they are only called by the original iteration
path.

Signed-off-by: Emanuele Giacomini <giacomini@diag.uniroma1.it>
---
 drivers/media/i2c/max96712.c | 50 +++++++++++++++---------------------
 1 file changed, 21 insertions(+), 29 deletions(-)

diff --git a/drivers/media/i2c/max96712.c b/drivers/media/i2c/max96712.c
--- a/drivers/media/i2c/max96712.c
+++ b/drivers/media/i2c/max96712.c
@@ -143,7 +143,7 @@
 }
 EXPORT_SYMBOL(max96712_read_reg_Dser);
 
-static int max96712_read_slave_reg(struct max96712 *priv,
+static int __maybe_unused max96712_read_slave_reg(struct max96712 *priv,
 			int ShortSlaveAddr, u16 addr, unsigned int *val)
 {
 	struct i2c_client *i2c_client = priv->i2c_client;
@@ -166,7 +166,7 @@
 	return err;
 }
 
-static int max96712_write_slave_reg(struct max96712 *priv,
+static int __maybe_unused max96712_write_slave_reg(struct max96712 *priv,
 			int ShortSlaveAddr, u16 addr, unsigned int val)
 {
 	struct i2c_client *i2c_client = priv->i2c_client;
@@ -673,38 +673,32 @@
 {
 	struct max96712 *priv = dev_get_drvdata(dev);
 	uint8_t link_mask = priv->link_mask;
-	unsigned int reg_val = 0;
 	unsigned int dser_empty_link_mask_reg = 0xF0;
-	uint8_t link_id_iter = 0;
-	unsigned default_ser_addr = MAX9295_DEFAULT_ADDR;
-	int err = 0;
 
-	/* Iterating over the links and assigning unique serializer i2c addresses */
-	for (link_id_iter = 0; link_id_iter < MAX96712_MAX_LINKS ; link_id_iter++)
-	{
-		if (link_mask & (1 << link_id_iter))
-		{
-			/* Camera should be connected on this link */
-			unsigned int dst_ser_addr = default_ser_addr + link_id_iter;
-			unsigned int curr_map = dser_empty_link_mask_reg | (1 << link_id_iter);
-
-			/* Enable single link */
-			max96712_write_reg(priv, MAX96712_REG6_ADDR, curr_map);
-			msleep(20);
-			max96712_reset_oneshot(dev);
-
-			err = max96712_read_slave_reg(priv, dst_ser_addr, 0, &reg_val);
-			if ((err == 0) && (reg_val == (dst_ser_addr << 1)))
-			{
-				dev_dbg(dev, "%s Serializer already at 0x%x\n", __func__, dst_ser_addr);
-				continue;
-			}
+	/*
+	 * LI-JAG-ADP-GMSL2-8CH variant of setup_link.
+	 *
+	 * The original upstream version iterates over each enabled link,
+	 * temporarily setting LINK_EN to a single-link bitmask, calling
+	 * max96712_reset_oneshot() (which writes 0x0018 = 0x0F resetting
+	 * ALL FOUR GMSL links), then attempting per-link MAX9295 i2c
+	 * address reassignment. On the LI-JAG board this destabilises the
+	 * camera-side MAX9295 across the intermediate single-link LINK_EN
+	 * states (0xF1, 0xF2, 0xF4, 0xF8) and the four successive resets,
+	 * leaving the deserializer forward I2C channel unable to reach the
+	 * camera-side serializer once the loop ends.
+	 *
+	 * For LI-JAG single-camera configurations we skip both the
+	 * iteration and the reassignment. Final LINK_EN is set once; with
+	 * link-mask=0xf in DT it lands at 0xFF (required for forward I2C
+	 * on this board) without disturbing any link in between. The
+	 * camera-side MAX9295 keeps its default i2c address (0x40), which
+	 * the DT max9295_a@40 node also expects.
+	 */
+	max96712_write_reg(priv, MAX96712_REG6_ADDR,
+			   dser_empty_link_mask_reg | link_mask);
+	msleep(20);
 
-			/* Assign the new i2c address */
-			max96712_write_slave_reg(priv, default_ser_addr, 0, dst_ser_addr << 1);
-		}
-	}
-	max96712_write_reg(priv, MAX96712_REG6_ADDR, dser_empty_link_mask_reg | link_mask);
 	return 0;
 }
 EXPORT_SYMBOL(max96712_setup_link);
