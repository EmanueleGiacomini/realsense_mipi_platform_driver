					ser_c: max9295_c@42 {
						status = "okay";
						compatible = "maxim,max9295";
						reg = <0x42>;
						maxim,gmsl-dser-device = <&dser_a>;
						external_addr_reassign;
					};

					ser_d: max9295_d@43 {
						status = "okay";
						compatible = "maxim,max9295";
						reg = <0x43>;
						maxim,gmsl-dser-device = <&dser_a>;
						external_addr_reassign;
					};

