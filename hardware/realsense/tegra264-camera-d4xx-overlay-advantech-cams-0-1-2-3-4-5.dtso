							pixel_t = "grey_y16";
							num_lanes = "2";
							csi_pixel_bit_depth = "16";
							active_w = "640";
							active_h = "480";
							tegra_sinterface = "serial_b";
							mclk_khz = "24000";
							pix_clk_hz = "74250000";
							line_length = "1280"; /* 2200 */
