				/* ---- First deserializer: cameras 0-3 on i2c9 ---- */
				i2c@810c6a0000 {
					clock-frequency = <100000>;

					dser_a: max96712@29 {
						status = "okay";
						reg = <0x29>;
						compatible = "maxim,max96712";
						csi-mode = "2x4";
						link-mask = <0xf>;
						channel = "a";
						force_clk0;
					};

					ser_a: max9295_a@40 {
						status = "okay";
						compatible = "maxim,max9295";
						reg = <0x40>;
						maxim,gmsl-dser-device = <&dser_a>;
						external_addr_reassign;
					};

					ser_b: max9295_b@41 {
						status = "okay";
						compatible = "maxim,max9295";
						reg = <0x41>;
						maxim,gmsl-dser-device = <&dser_a>;
