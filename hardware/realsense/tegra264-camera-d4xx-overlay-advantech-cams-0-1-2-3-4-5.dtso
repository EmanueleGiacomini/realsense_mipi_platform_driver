				/* ---- Second deserializer: cameras 4-5 on i2c12 ---- */
				i2c@810c6d0000 {
					clock-frequency = <100000>;

					dser_b: max96712@29 {
						status = "okay";
						reg = <0x29>;
						compatible = "maxim,max96712";
						csi-mode = "2x4";
						link-mask = <0x3>;
						channel = "b";
						force_clk0;
					};

					ser_e: max9295_a@40 {
						status = "okay";
						compatible = "maxim,max9295";
						reg = <0x40>;
						maxim,gmsl-dser-device = <&dser_b>;
						external_addr_reassign;
					};

